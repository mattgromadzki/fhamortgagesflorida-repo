  "bodyHtml": "<div class=\"crumbs\"><div class=\"wrap\"><a href=\"index.html\">Home</a><span>/</span>Get Pre-Approved</div></div>\n<section style=\"padding:clamp(38px,7vw,76px) 0 26px\"><div class=\"wrap\"><div style=\"max-width:720px;margin:0 auto;text-align:center\">\n<span class=\"eyebrow\" style=\"justify-content:center\">Free FHA Pre-Approval</span>\n<h1 style=\"margin:10px 0 10px\">Get pre-approved in <span class=\"hl\">minutes</span></h1>\n<p class=\"lead\" style=\"margin:0 auto\">Answer a few quick questions and a licensed FHA specialist will follow up with your personalized options. It takes about 2 minutes &mdash; and it won't affect your credit.</p>\n</div></div></section>\n<section style=\"padding-top:0\"><div class=\"wrap\"><div class=\"pa-wrap\">\n<div class=\"pa-progress\"><span id=\"paBar\" style=\"width:11%\"></span></div>\n<div class=\"pa-stepcount\" id=\"paCount\">Step 1 of 9</div>\n<div id=\"paBody\" aria-live=\"polite\"></div>\n<div class=\"pa-trust\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 2l8 3v6c0 5-3.5 8-8 11-4.5-3-8-6-8-11V5l8-3z\" stroke=\"currentColor\" stroke-width=\"1.6\"/></svg> Your information is secure and never sold.</div>\n</div></div></section>\n<script>(function(){\nvar KEY=\"__WEB3KEY__\";\nvar COUNTIES=[\"Alachua\",\"Baker\",\"Bay\",\"Bradford\",\"Brevard\",\"Broward\",\"Calhoun\",\"Charlotte\",\"Citrus\",\"Clay\",\"Collier\",\"Columbia\",\"DeSoto\",\"Dixie\",\"Duval\",\"Escambia\",\"Flagler\",\"Franklin\",\"Gadsden\",\"Gilchrist\",\"Glades\",\"Gulf\",\"Hamilton\",\"Hardee\",\"Hendry\",\"Hernando\",\"Highlands\",\"Hillsborough\",\"Holmes\",\"Indian River\",\"Jackson\",\"Jefferson\",\"Lafayette\",\"Lake\",\"Lee\",\"Leon\",\"Levy\",\"Liberty\",\"Madison\",\"Manatee\",\"Marion\",\"Martin\",\"Miami-Dade\",\"Monroe\",\"Nassau\",\"Okaloosa\",\"Okeechobee\",\"Orange\",\"Osceola\",\"Palm Beach\",\"Pasco\",\"Pinellas\",\"Polk\",\"Putnam\",\"Santa Rosa\",\"Sarasota\",\"Seminole\",\"St. Johns\",\"St. Lucie\",\"Sumter\",\"Suwannee\",\"Taylor\",\"Union\",\"Volusia\",\"Wakulla\",\"Walton\",\"Washington\"];\nvar STEPS=[\n {key:\"goal\",type:\"choice\",q:\"What would you like to do?\",sub:\"Let's start with your goal.\",options:[\"Buy a home\",\"Refinance my home\",\"I'm just exploring\"]},\n {key:\"stage\",type:\"choice\",q:\"Where are you in the process?\",options:[\"Just getting started\",\"Still looking\",\"Found a home I like\",\"Making an offer\",\"Already under contract\"]},\n {key:\"propertyType\",type:\"choice\",q:\"What type of property?\",options:[\"Single-family home\",\"Townhouse\",\"Condo\",\"Multi-unit (2-4 units)\"]},\n {key:\"county\",type:\"select\",q:\"Which Florida county?\",sub:\"This determines your FHA loan limit.\",options:COUNTIES,placeholder:\"Select your county\",extra:\"Not sure yet\"},\n {key:\"price\",type:\"slider\",q:\"What's the estimated purchase price?\",min:100000,max:1250000,step:5000,def:400000,fmt:\"money\"},\n {key:\"downPct\",type:\"slider\",q:\"How much do you plan to put down?\",sub:\"FHA's minimum is 3.5%.\",min:3.5,max:25,step:0.5,def:3.5,fmt:\"pct\"},\n {key:\"credit\",type:\"choice\",q:\"How would you rate your credit?\",sub:\"An estimate is fine - this is not a credit check.\",options:[\"Excellent (720+)\",\"Good (680-719)\",\"Fair (620-679)\",\"Building (below 620)\",\"Not sure\"]},\n {key:\"firstTime\",type:\"choice\",q:\"Are you a first-time home buyer?\",options:[\"Yes\",\"No\"]},\n {key:\"contact\",type:\"contact\",q:\"Where should we send your options?\",sub:\"A licensed FHA specialist will reach out - no obligation.\"}\n];\nvar state={},i=0;\nvar root=document.getElementById(\"paBody\"),bar=document.getElementById(\"paBar\"),cnt=document.getElementById(\"paCount\");\nfunction money(n){return \"$\"+Number(n).toLocaleString(\"en-US\");}\nfunction esc(s){return String(s).replace(/\"/g,\"&quot;\");}\nfunction setProg(){bar.style.width=Math.round((i/STEPS.length)*100)+\"%\";cnt.textContent=\"Step \"+(i+1)+\" of \"+STEPS.length;}\nfunction qText(s){return (s.key===\"price\"&&state.goal===\"Refinance my home\")?\"What's your home's estimated value?\":s.q;}\nfunction render(){\n setProg();var s=STEPS[i];\n var h='<div class=\"pa-card\"><div class=\"pa-q\">'+qText(s)+'</div>'+(s.sub?'<div class=\"pa-sub\">'+s.sub+'</div>':'');\n if(s.type===\"choice\"){\n  h+='<div class=\"pa-opts\">';\n  for(var k=0;k<s.options.length;k++){var o=s.options[k];h+='<button type=\"button\" class=\"pa-opt\" data-val=\"'+esc(o)+'\" aria-pressed=\"'+(state[s.key]===o?\"true\":\"false\")+'\">'+o+'<span class=\"arr\">&rarr;</span></button>';}\n  h+='</div>';\n }else if(s.type===\"select\"){\n  h+='<div class=\"pa-field\"><select id=\"paSel\"><option value=\"\">'+(s.placeholder||\"Select\")+'</option>';\n  for(var j=0;j<s.options.length;j++){var c=s.options[j];h+='<option'+(state[s.key]===c?\" selected\":\"\")+'>'+c+'</option>';}\n  if(s.extra)h+='<option'+(state[s.key]===s.extra?\" selected\":\"\")+'>'+s.extra+'</option>';\n  h+='</select></div>';\n }else if(s.type===\"slider\"){\n  var val=state[s.key]!=null?state[s.key]:s.def;\n  h+='<div class=\"pa-slider-val\" id=\"paVal\"></div><input type=\"range\" class=\"pa-slider\" id=\"paRange\" min=\"'+s.min+'\" max=\"'+s.max+'\" step=\"'+s.step+'\" value=\"'+val+'\">';\n  if(s.key===\"downPct\")h+='<div class=\"pa-hint\" id=\"paHint\"></div>';\n }else if(s.type===\"contact\"){\n  h+='<div class=\"pa-row\"><div class=\"pa-field\"><label>First name</label><input id=\"paFirst\" autocomplete=\"given-name\" value=\"'+esc(state.firstName||\"\")+'\"></div><div class=\"pa-field\"><label>Last name</label><input id=\"paLast\" autocomplete=\"family-name\" value=\"'+esc(state.lastName||\"\")+'\"></div></div>';\n  h+='<div class=\"pa-field\"><label>Email</label><input id=\"paEmail\" type=\"email\" autocomplete=\"email\" value=\"'+esc(state.email||\"\")+'\"></div>';\n  h+='<div class=\"pa-field\"><label>Phone</label><input id=\"paPhone\" type=\"tel\" autocomplete=\"tel\" value=\"'+esc(state.phone||\"\")+'\"></div>';\n  h+='<div class=\"pa-err\" id=\"paErr\"></div>';\n  h+='<label class=\"pa-consent\"><input type=\"checkbox\" id=\"paConsent\"><span>I agree to be contacted by FHA Mortgages Florida about my inquiry by phone, text, or email. This is not a credit check and creates no obligation.</span></label>';\n }\n h+='<div class=\"pa-nav\"><button type=\"button\" class=\"pa-back\" id=\"paBack\"'+(i===0?\" hidden\":\"\")+'>&larr; Back</button>';\n if(s.type===\"choice\"){h+='<span></span>';}\n else if(s.type===\"contact\"){h+='<button type=\"button\" class=\"btn btn-primary\" id=\"paSubmit\">Get my pre-approval options</button>';}\n else{h+='<button type=\"button\" class=\"btn btn-primary\" id=\"paNext\">Continue</button>';}\n h+='</div></div>';\n root.innerHTML=h;\n if(s.type===\"choice\"){\n  var btns=root.querySelectorAll(\".pa-opt\");\n  for(var b=0;b<btns.length;b++){btns[b].addEventListener(\"click\",function(){state[s.key]=this.getAttribute(\"data-val\");next();});}\n  if(btns[0])btns[0].focus();\n }else if(s.type===\"select\"){\n  document.getElementById(\"paNext\").addEventListener(\"click\",function(){var v=document.getElementById(\"paSel\").value;if(!v)return;state[s.key]=v;next();});\n }else if(s.type===\"slider\"){\n  var r=document.getElementById(\"paRange\"),vv=document.getElementById(\"paVal\");\n  function upd(){var v=parseFloat(r.value);state[s.key]=v;if(s.fmt===\"money\"){vv.textContent=money(v);}else{vv.textContent=v+\"%\";var hint=document.getElementById(\"paHint\");var pr=state.price||400000;if(hint)hint.textContent=money(Math.round(pr*v/100))+\" down payment\";}}\n  r.addEventListener(\"input\",upd);upd();\n  document.getElementById(\"paNext\").addEventListener(\"click\",function(){if(state[s.key]==null)state[s.key]=parseFloat(r.value);next();});\n }else if(s.type===\"contact\"){\n  document.getElementById(\"paSubmit\").addEventListener(\"click\",submit);\n }\n var bk=document.getElementById(\"paBack\");if(bk)bk.addEventListener(\"click\",function(){if(i>0){i--;render();}});\n}\nfunction next(){if(i<STEPS.length-1){i++;render();}}\nfunction vEmail(e){return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(e);}\nfunction submit(){\n state.firstName=document.getElementById(\"paFirst\").value.trim();\n state.lastName=document.getElementById(\"paLast\").value.trim();\n state.email=document.getElementById(\"paEmail\").value.trim();\n state.phone=document.getElementById(\"paPhone\").value.trim();\n var ok=document.getElementById(\"paConsent\").checked,err=document.getElementById(\"paErr\");\n function show(m){err.textContent=m;err.style.display=\"block\";}\n if(!state.firstName||!state.lastName)return show(\"Please enter your first and last name.\");\n if(!vEmail(state.email))return show(\"Please enter a valid email address.\");\n if(state.phone.replace(/\\D/g,\"\").length<10)return show(\"Please enter a valid phone number.\");\n if(!ok)return show(\"Please agree to be contacted to continue.\");\n err.style.display=\"none\";\n var btn=document.getElementById(\"paSubmit\");btn.disabled=true;btn.textContent=\"Submitting...\";\n var price=state.price||0,dp=state.downPct||0;\n var summary=\"Goal: \"+(state.goal||\"-\")+\"\\nStage: \"+(state.stage||\"-\")+\"\\nProperty type: \"+(state.propertyType||\"-\")+\"\\nCounty: \"+(state.county||\"-\")+\"\\nEstimated price/value: \"+money(price)+\"\\nDown payment: \"+dp+\"% (\"+money(Math.round(price*dp/100))+\")\\nCredit estimate: \"+(state.credit||\"-\")+\"\\nFirst-time buyer: \"+(state.firstTime||\"-\");\n var payload={access_key:KEY,subject:\"New FHA pre-approval lead - \"+state.firstName+\" \"+state.lastName,from_name:\"FHA Mortgages Florida\",name:state.firstName+\" \"+state.lastName,email:state.email,phone:state.phone,goal:state.goal,stage:state.stage,property_type:state.propertyType,county:state.county,estimated_price:money(price),down_payment:dp+\"%\",credit:state.credit,first_time_buyer:state.firstTime,message:summary,botcheck:\"\"};\n fetch(\"https://api.web3forms.com/submit\",{method:\"POST\",headers:{\"Content-Type\":\"application/json\",Accept:\"application/json\"},body:JSON.stringify(payload)}).then(function(r){return r.json();}).then(function(){done();}).catch(function(){done();});\n}\nfunction done(){\n bar.style.width=\"100%\";cnt.textContent=\"Done\";\n root.innerHTML='<div class=\"pa-card pa-success\"><div class=\"ic\"><svg width=\"34\" height=\"34\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 12l5 5L20 6\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div><div class=\"pa-q\">You\\'re all set, '+(state.firstName||\"\")+'!</div><p class=\"pa-sub\">A licensed FHA specialist will review your information and reach out shortly with your personalized pre-approval options. No obligation &mdash; and this didn\\'t affect your credit.</p><div class=\"hero-cta\" style=\"justify-content:center\"><a href=\"index.html\" class=\"btn btn-primary\">Back to home</a><a href=\"blog.html\" class=\"btn btn-ghost\">Read FHA guides</a></div></div>';\n}\nrender();\n})();</script>",
