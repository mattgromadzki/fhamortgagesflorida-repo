---
import { settings } from '../lib/render';
const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const date = new Date(d.pubDate);
const dstr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const faqSchema = d.faqs && d.faqs.length
  ? JSON.stringify({ '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: d.faqs.map((f: any) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) })
  : null;
const postSchema = JSON.stringify({ '@context': 'https://schema.org', '@type': 'BlogPosting', headline: d.title, description: d.description, datePublished: date.toISOString().slice(0, 10), author: { '@type': 'Organization', name: settings.brand }, publisher: { '@type': 'Organization', name: settings.brand } });
---
<div class="crumbs"><div class="wrap"><a href="/index.html">Home</a><span>/</span><a href="/blog.html">Blog</a><span>/</span>{d.title}</div></div>
<section class="hero"><div class="wrap"><div class="hero-copy" style="max-width:820px">
  <span class="eyebrow">FHA Blog</span>
  <h1>{d.title}</h1>
  <p class="lead">{d.description}</p>
  <p style="opacity:.7;font-size:.95rem;margin-top:6px">Updated {dstr}</p>
</div></div></section>
<section><div class="wrap"><article class="prose reveal" style="max-width:760px"><Content /></article></div></section>
{d.faqs && d.faqs.length > 0 && (
  <section class="alt"><div class="wrap">
    <div class="sec-head center reveal" style="text-align:center;margin-inline:auto"><span class="eyebrow" style="justify-content:center">Questions &amp; Answers</span><h2>Frequently asked questions</h2></div>
    <div class="faq-list">{d.faqs.map((f: any) => (
      <details class="faq reveal"><summary set:html={f.q + '<span class=\"pl\">+</span>'}></summary><div class="ans"><p>{f.a}</p></div></details>
    ))}</div>
  </div></section>
)}
{d.related && d.related.length > 0 && (
  <section><div class="wrap">
    <div class="sec-head reveal"><span class="eyebrow">Keep Exploring</span><h2 style="font-size:1.8rem">Related resources</h2></div>
    <div class="related reveal">{d.related.map((r: any) => (<a href={'/' + r.href}>{r.label}</a>))}</div>
  </div></section>
)}
<section style="padding-top:0"><div class="wrap"><div class="final reveal"><h2>Ready to get started?</h2><p>Get a free FHA rate quote and pre-approval from a local specialist.</p><a href="/get-pre-approved.html" class="btn btn-ink">Get Pre-Approved Now</a></div></div></section>
<script type="application/ld+json" set:html={postSchema} />
{faqSchema && <script type="application/ld+json" set:html={faqSchema} />}
